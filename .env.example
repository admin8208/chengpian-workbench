# Copy this file to .env.local for local development or to a deployment-specific
# environment file. Do not put real secrets in this example file.

CHENGPIAN_DATABASE_URL=postgresql+psycopg://chengpian:password@127.0.0.1:5432/chengpian
CHENGPIAN_REDIS_URL=redis://127.0.0.1:6379/0

# Keep runtime data outside the source tree in production, for example:
# CHENGPIAN_DATA_DIR=/var/lib/chengpian
CHENGPIAN_DATA_DIR=./data

CHENGPIAN_API_HOST=127.0.0.1
CHENGPIAN_API_PORT=8010
CHENGPIAN_RELOAD=1
CHENGPIAN_EXPOSE_DOCS=0
CHENGPIAN_COOKIE_SECURE=auto

# Use a stable random value in production. Existing file URLs signed with the
# old value will stop working after changing this secret.
CHENGPIAN_FILE_TOKEN_SECRET=change-me-to-a-long-random-secret
